extend type Query {
  adminRoomStats: AdminRoomStats
  adminUserStats: AdminUserStats
  adminAnnouncementStats: AdminAnnouncementStats
  adminQnaStats: AdminQnaStats
}

type AdminUserStats {
  totalCount: Int!
  verifiedCount: Int!
  pendingCount: Int!
}

type AdminRoomStats {
  totalCount: Int!
  membershipCount: Int!
  activeRoomCount: Int!
  managingUserCount: Int!
  participantCount: Int!
}

type AdminAnnouncementStats {
  totalCount: Int!
}

type AdminQnaStats {
  postCount: Int!
}
